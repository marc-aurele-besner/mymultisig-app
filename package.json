{
  "name": "mymultisig-app",
  "version": "0.0.1",
  "description": "Next.js Web App for mymultisig.app",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "src/*"
  ],
  "main": "index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marc-aurele-besner/mymultisig-app.git"
  },
  "keywords": [
    "nextjs",
    "react",
    "typescript",
    "web3",
    "ethereum",
    "multisig",
    "wallet",
    "dapp"
  ],
  "author": "Marc-Aurele Besner <82244926+marc-aurele-besner@users.noreply.github.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/marc-aurele-besner/mymultisig-app/issues"
  },
  "scripts": {
    "start": "bash ./start.sh",
    "prepare": "husky",
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "lint": "next build lint",
    "prettier": "prettier -l \"./src/**/*.{js,jsx,ts,tsx,md}\"",
    "export": "EXPORT=true turbo build && EXPORT=true turbo export",
    "analyze": "ANALYZE=true turbo build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test-storybook": "lerna run test-storybook"
  },
  "husky": {
    "hooks": {
      "pre-commit": "yarn format:check",
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS"
    }
  },
  "lint-staged": {
    "src/**/*.{js,ts,jsx,tsx}": [
      "eslint --fix"
    ],
    "*.json": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@coinbase/wallet-sdk": "^4.3.6",
    "@ethersproject/abi": "^5.8.0",
    "@metamask/sdk": "^0.33.1",
    "@neondatabase/serverless": "^1.0.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.19",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@tailwindcss/postcss": "^4.2.1",
    "@tanstack/react-query": "^5.90.16",
    "@walletconnect/ethereum-provider": "^2.23.7",
    "@web3icons/react": "^4.1.17",
    "autoprefixer": "^10.4.27",
    "axios": "^1.13.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^0.577.0",
    "mymultisig-contract": "0.5.1",
    "next-pwa": "^5.6.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-icons": "^5.5.0",
    "react-merge-refs": "^3.0.2",
    "resend": "^6.17.2",
    "sonner": "^2.0.7",
    "styled-components": "^6.1.19",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "uuid": "^13.0.0",
    "viem": "^2.43.3",
    "wagmi": "^3.1.3"
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@commitlint/cli": "^20.2.0",
    "@commitlint/config-conventional": "^20.2.0",
    "@next/bundle-analyzer": "^16.1.1",
    "@storybook/addon-a11y": "^10.1.11",
    "@storybook/addon-docs": "^10.1.11",
    "@storybook/addon-links": "^10.1.11",
    "@storybook/nextjs": "^10.1.11",
    "@storybook/react": "^10.1.11",
    "@types/minimatch": "^6.0.0",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/styled-components": "^5.1.36",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8",
